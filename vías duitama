<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Huecos en las Vías - Duitama</title>
    
    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f5f5f5;
        }

        header {
            background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
            color: white;
            padding: 30px;
            text-align: center;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }

        header h1 {
            font-size: 2.5em;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
        }

        .container {
            display: flex;
            flex-wrap: wrap;
            min-height: calc(100vh - 120px);
            gap: 20px;
            padding: 20px;
            max-width: 1400px;
            margin: 0 auto;
        }

        .map-section {
            flex: 1;
            min-width: 300px;
            background-color: white;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            overflow: hidden;
        }

        #map {
            width: 100%;
            height: 100%;
            min-height: 500px;
        }

        .form-section {
            flex: 1;
            min-width: 300px;
            background-color: white;
            border-radius: 8px;
            padding: 30px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }

        .form-section h2 {
            color: #f57c00;
            margin-bottom: 25px;
            font-size: 1.5em;
            border-bottom: 3px solid #ff9800;
            padding-bottom: 10px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            margin-bottom: 8px;
            color: #333;
            font-weight: 600;
            font-size: 0.95em;
        }

        select,
        textarea {
            width: 100%;
            padding: 12px;
            border: 2px solid #e0e0e0;
            border-radius: 4px;
            font-size: 1em;
            font-family: inherit;
            transition: border-color 0.3s ease;
        }

        select:focus,
        textarea:focus {
            outline: none;
            border-color: #ff9800;
            box-shadow: 0 0 5px rgba(255, 152, 0, 0.3);
        }

        select {
            cursor: pointer;
            background-color: white;
        }

        select option {
            padding: 8px;
        }

        textarea {
            resize: vertical;
            min-height: 120px;
            max-height: 300px;
        }

        button {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
            color: white;
            border: none;
            border-radius: 4px;
            font-size: 1.1em;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 6px rgba(255, 152, 0, 0.3);
        }

        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(255, 152, 0, 0.4);
        }

        button:active {
            transform: translateY(0);
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .success-message {
            display: none;
            background-color: #4caf50;
            color: white;
            padding: 15px;
            border-radius: 4px;
            margin-bottom: 20px;
            animation: slideIn 0.3s ease;
        }

        .success-message.show {
            display: block;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @media (max-width: 768px) {
            .container {
                flex-direction: column;
                min-height: auto;
            }

            header h1 {
                font-size: 1.8em;
            }

            .form-row {
                grid-template-columns: 1fr;
            }

            #map {
                min-height: 400px;
            }
        }
    </style>
</head>
<body>
    <header>
        <h1>🛣️ Huecos en las Vías - Duitama</h1>
    </header>

    <div class="container">
        <!-- Sección del Mapa -->
        <div class="map-section">
            <div id="map"></div>
        </div>

        <!-- Sección del Formulario -->
        <div class="form-section">
            <h2>Reportar Hueco</h2>
            
            <div class="success-message" id="successMessage">
                ✓ Reporte enviado correctamente. ¡Gracias por reportar!
            </div>

            <form id="reportForm">
                <div class="form-row">
                    <div class="form-group">
                        <label for="gravedad">Gravedad del Hueco:</label>
                        <select id="gravedad" name="gravedad" required>
                            <option value="">-- Selecciona gravedad --</option>
                            <option value="leve">Leve</option>
                            <option value="grave">Grave</option>
                            <option value="peligroso">Peligroso</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="tamaño">Tamaño Aproximado:</label>
                        <select id="tamaño" name="tamaño" required>
                            <option value="">-- Selecciona tamaño --</option>
                            <option value="pequeño">Pequeño</option>
                            <option value="mediano">Mediano</option>
                            <option value="grande">Grande</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label for="descripcion">Descripción:</label>
                    <textarea id="descripcion" name="descripcion" placeholder="Proporciona detalles adicionales sobre el hueco..." required></textarea>
                </div>

                <button type="submit">Enviar Reporte</button>
            </form>
        </div>
    </div>

    <!-- Leaflet JavaScript -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>

    <script>
        // Inicializar el mapa
        const map = L.map('map').setView([5.8268, -73.0333], 14);

        // Agregar capa de OpenStreetMap
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors',
            maxZoom: 19,
            maxNativeZoom: 18
        }).addTo(map);

        // Marcador para el centro de Duitama
        L.marker([5.8268, -73.0333], {
            title: 'Centro de Duitama'
        }).bindPopup('<b>Duitama</b><br>Centro de la ciudad').addTo(map);

        // Manejar el formulario
        const form = document.getElementById('reportForm');
        const successMessage = document.getElementById('successMessage');

        form.addEventListener('submit', function(e) {
            e.preventDefault();

            // Obtener datos del formulario
            const gravedad = document.getElementById('gravedad').value;
            const tamaño = document.getElementById('tamaño').value;
            const descripcion = document.getElementById('descripcion').value;

            // Crear objeto con los datos
            const reportData = {
                gravedad: gravedad,
                tamaño: tamaño,
                descripcion: descripcion,
                fecha: new Date().toLocaleString('es-CO'),
                coordenadas: {
                    lat: map.getCenter().lat,
                    lng: map.getCenter().lng
                }
            };

            console.log('Reporte enviado:', reportData);

            // Mostrar mensaje de éxito
            successMessage.classList.add('show');

            // Limpiar formulario
            form.reset();

            // Ocultar mensaje después de 4 segundos
            setTimeout(() => {
                successMessage.classList.remove('show');
            }, 4000);
        });

        // Agregar evento de clic en el mapa para obtener coordenadas
        map.on('click', function(e) {
            console.log('Coordenadas seleccionadas:', e.latlng.lat, e.latlng.lng);
        });
    </script>
</body>
</html>
